<?xml version="1.0" encoding="UTF-8"?>
<!-- 어떤 상황에서도 같은 포맷으로 적재되게 지정 — 콘솔은 사람용 패턴, 운영 파일은 ELK가 파싱할 JSON -->
<configuration>
    <property name="PATTERN"
              value="%d{HH:mm:ss.SSS} %-5level [%thread] [%X{traceId:-}] [%X{memberId:-}] %logger{36} - %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${PATTERN}</pattern>
        </encoder>
    </appender>

    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="prod">
        <!-- 운영은 콘솔이 없다(jar/도커) — 파일에 적재해 두는 것까지가 로그백, 가져가는 건 ELK의 역할 -->
        <appender name="FILE_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>/var/log/susuggang/app.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <!-- 하루 단위 롤링 + 파일당 50MB, 보관 14일·총 1GB 상한 — 디스크가 로그로 차는 사고 방지 -->
                <fileNamePattern>/var/log/susuggang/app.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>14</maxHistory>
                <totalSizeCap>1GB</totalSizeCap>
            </rollingPolicy>
            <!-- MDC(traceId·memberId)가 JSON 필드로 자동 포함 → Kibana에서 키로 검색하는 그림 -->
            <encoder class="net.logstash.logback.encoder.LogstashEncoder"/>
        </appender>
        <root level="INFO">
            <!-- docker logs로도 보게 콘솔은 유지 -->
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE_JSON"/>
        </root>
    </springProfile>
</configuration>
